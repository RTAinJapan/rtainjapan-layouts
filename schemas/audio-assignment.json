{
	"$schema": "http://json-schema.org/draft-04/schema",

	"type": "object",
	"additionalProperties": false,
	"description": "Channel assignment for current and next runs. deck はテンプレート選択用、runners/commentators は実 ch 割り当て (-1 = 未割当)。",
	"properties": {
		"current": {"$ref": "#/definitions/deckAssignment"},
		"next": {"$ref": "#/definitions/deckAssignment"}
	},
	"definitions": {
		"deckAssignment": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"deck": {
					"type": ["string", "null"],
					"enum": ["A", "B", null]
				},
				"runners": {
					"type": "array",
					"items": {"type": "number"},
					"description": "runner index → WING meter index (-1 = 未割当)"
				},
				"commentators": {
					"type": "array",
					"items": {"type": "number"},
					"description": "commentator index → WING meter index (-1 = 未割当)"
				}
			},
			"required": ["deck", "runners", "commentators"]
		}
	},
	"default": {
		"current": {"deck": null, "runners": [], "commentators": []},
		"next": {"deck": null, "runners": [], "commentators": []}
	}
}
