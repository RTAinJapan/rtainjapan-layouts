{
	"$schema": "http://json-schema.org/draft-04/schema",

	"type": "object",
	"additionalProperties": false,
	"description": "A卓/B卓ごとのテンプレート。プルダウンで卓を選んだときに current/next の channels に流し込まれる。runners は runner index → WING meter index、commentators は commentator index → WING meter index。",
	"properties": {
		"A": {"$ref": "#/definitions/deckTemplate"},
		"B": {"$ref": "#/definitions/deckTemplate"}
	},
	"definitions": {
		"deckTemplate": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"runners": {
					"type": "array",
					"items": {"type": "number"},
					"description": "runner index → WING meter index"
				},
				"commentators": {
					"type": "array",
					"items": {"type": "number"},
					"description": "commentator index → WING meter index"
				}
			},
			"required": ["runners", "commentators"]
		}
	},
	"default": {
		"A": {"runners": [0, 1, 2, 3], "commentators": [4, 5]},
		"B": {"runners": [16, 17, 18, 19], "commentators": [20, 21]}
	}
}
